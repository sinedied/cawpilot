{
  "name": "cawpilot",
  "version": "0.1.0",
  "description": "On-call coding copilot — talk to GitHub Copilot from Signal, WhatsApp, or Telegram",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "cawpilot": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "tsx src/index.ts",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "copilot",
    "agent",
    "signal",
    "bot",
    "ai",
    "coding-assistant"
  ],
  "author": "sinedied",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@inquirer/prompts": "^7.0.0",
    "@octokit/rest": "^21.0.0",
    "commander": "^13.0.0",
    "localtunnel": "^2.0.2",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
