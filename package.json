{
  "name": "cawpilot",
  "version": "0.1.0",
  "description": "Autonomous agent assistant built on GitHub Copilot SDK, accessible via Telegram, HTTP API, and CLI",
  "type": "module",
  "bin": {
    "cawpilot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "copilot",
    "agent",
    "telegram",
    "assistant",
    "github"
  ],
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@inquirer/prompts": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "express": "^5.0.0",
    "grammy": "^1.35.0",
    "localtunnel": "^2.0.2",
    "ora": "^8.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/localtunnel": "^2.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
